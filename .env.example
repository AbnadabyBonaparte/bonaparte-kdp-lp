# Resend API key — required
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — optional
# While DNS for your custom domain is propagating, leave this unset to use the Resend sandbox sender.
# Once your domain is verified in Resend, set to e.g.: Casa Bonaparte <noreply@casabonaparte.com>
RESEND_FROM=

# Admin notification address — optional
# If set, a copy of each new lead is emailed to this address.
ADMIN_EMAIL=

# Webhook base para captura nas LPs de livro (Vite / cliente).
# Ex.: https://seu-n8n.app/webhook/bonaparte — o slug do livro é acrescentado (/cartografia, /heimat, …).
# Se definido, substitui o `emailWebhookUrl` de cada `config.ts`.
# VITE_LEAD_WEBHOOK_BASE=

# Subdomínios por livro: `cartografia.<base>`, `heimat.<base>`, … (detecção no cliente).
# VITE_BOOK_HOST_BASE=casabonaparte.com.br

# Hub quando o visitante está num host de livro (link «Hub» / Casa Bonaparte nas LPs).
# Por defeito: https://bonaparte.alshamglobal.com.br
# VITE_HUB_ORIGIN=https://bonaparte.alshamglobal.com.br
